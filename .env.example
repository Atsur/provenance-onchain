# ─────────────────────────────────────────────────────────────────────────
# Atsur Provenance Onchain — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — deployer account private key (no 0x prefix or with, either works).
# Used by every deploy/role/timelock script and by Deploy.s.sol (vm.envUint).
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# REQUIRED for deployment — hot wallet address that will receive OPERATOR_ROLE
# (registry) and BATCH_COMMITTER_ROLE (provenance). This is the backend's
# day-to-day signing key, separate from admin/upgrade authority.
OPERATOR_ADDRESS=YOUR_OPERATOR_ADDRESS_HERE

# OPTIONAL — receives PAUSER_ROLE on AtsurProvenance. Defaults to the deployer
# address if not set. Should be a key your on-call team can act on quickly.
PAUSER_ADDRESS=YOUR_PAUSER_ADDRESS_HERE

# OPTIONAL for testnets, REQUIRED before mainnet — Gnosis Safe address that
# receives DEFAULT_ADMIN_ROLE. Must already be a deployed Safe (deploy scripts
# verify multisig.code.length > 0 and revert otherwise). Leave unset only for
# local/testnet deploys where the deployer keeps admin.
MULTISIG_ADDRESS=YOUR_GNOSIS_SAFE_ADDRESS_HERE

# OPTIONAL — TimelockController delay in seconds. Defaults to 172800 (48h) in
# Deploy.s.sol if unset. Must be >= 86400 (24h) on any non-local network; the
# deploy scripts will revert with "Timelock delay too short for production"
# otherwise. Has no effect on local/Anvil/Hardhat-network deploys.
TIMELOCK_DELAY=172800

# REQUIRED by setupTimelock.js, grantRoles.js, and any script that targets an
# already-deployed contract — the deployed AtsurActorRegistry proxy address.
REGISTRY_ADDRESS=YOUR_DEPLOYED_REGISTRY_PROXY_ADDRESS_HERE

# REQUIRED by setupTimelock.js, grantRoles.js, and any script that targets an
# already-deployed contract — the deployed AtsurProvenance proxy address.
PROVENANCE_ADDRESS=YOUR_DEPLOYED_PROVENANCE_PROXY_ADDRESS_HERE

# OPTIONAL — RPC URL for Ethereum Sepolia testnet (chain ID 11155111). Falls
# back to a public dRPC endpoint in hardhat.config.js if unset — for anything
# beyond light testing, use your own Infura/Alchemy/dRPC key here instead.
SEPOLIA_RPC_URL=https://sepolia.drpc.org

# OPTIONAL — RPC URL for Lisk mainnet (chain ID 1135). Falls back to the public
# endpoint in hardhat.config.js if unset.
LISK_RPC_URL=https://rpc.api.lisk.com

# OPTIONAL — RPC URL for Lisk Sepolia testnet (chain ID 4202). Falls back to
# the public endpoint in hardhat.config.js if unset.
LISK_SEPOLIA_RPC_URL=https://rpc.sepolia-api.lisk.com

# OPTIONAL — Blockscout API key for verifying contracts on Lisk Sepolia.
# Separate system from ETHERSCAN_API_KEY below — Lisk's explorer is Blockscout,
# not Etherscan.
LISK_SEPOLIA_API_KEY=YOUR_LISK_SEPOLIA_BLOCKSCOUT_API_KEY_HERE

# OPTIONAL — RPC URL for Polygon mainnet (chain ID 137). Falls back to the
# public endpoint in hardhat.config.js if unset.
POLYGON_RPC_URL=https://polygon-rpc.com

# OPTIONAL — Etherscan API key (V2 multichain). A single key now verifies
# contracts on Ethereum Sepolia, Polygon mainnet, and Polygon Amoy — Polygonscan
# keys were folded into this same Etherscan account/API system. Get one at
# https://etherscan.io/myapikey.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# OPTIONAL — CoinMarketCap API key, used by hardhat-gas-reporter to show gas
# costs in USD when REPORT_GAS=true.
COINMARKETCAP_API_KEY=YOUR_COINMARKETCAP_API_KEY_HERE

# REQUIRED only when deploying to a known mainnet chain ID (Polygon 137,
# Lisk 1135) — must be set to exactly "I_UNDERSTAND_THIS_IS_MAINNET" or the
# deploy scripts (Deploy.s.sol and deployAll.js) will refuse to run. This is
# a deliberate speed bump against an accidental mainnet deploy.
CONFIRM_MAINNET=
