{
  "name": "atsur-registry-onchain",
  "version": "1.0.0",
  "description": "Smart contracts for ATSUR Registry provenance event logging",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:foundry": "forge test",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:lisk-sepolia": "hardhat run scripts/deploy.js --network liskSepolia",
    "deploy:polygon-mumbai": "hardhat run scripts/deploy.js --network polygonMumbai",
    "verify": "hardhat verify",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "forge fmt"
  },
  "keywords": [
    "solidity",
    "smart-contracts",
    "provenance",
    "merkle-tree",
    "blockchain"
  ],
  "author": "ATSUR Technologies",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.11",
    "solhint": "^4.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "merkletreejs": "^0.3.11",
    "keccak256": "^1.0.6"
  }
}

